tags$p(style="color:#F7931A;font-size:28px;font-weight:700;margin:0;font-family:monospace;",
paste0("ARIMA(", p_, ", ", d_, ", ", q_, ")")),
tags$p(style="color:rgba(255,255,255,0.4);font-size:11px;margin:4px 0 0;",
"sobre retornos diarios")
),
# metricas en chips
fluidRow(
column(6, div(class="schip",
span(class="schip-num", style="font-size:17px;", aic),
span(class="schip-lbl", "AIC"))),
column(6, div(class="schip",
span(class="schip-num", style="font-size:17px;", bic),
span(class="schip-lbl", "BIC")))
),
div(class="schip", span(class="schip-num", style="font-size:17px;", sig),
span(class="schip-lbl", "Desv. Est. del error (sigma)")),
# interpretacion
tags$div(class="narrativa", style="margin-top:8px;",
tags$b(paste0("Que significa ARIMA(", p_, ",", d_, ",", q_, "):")), tags$br(),
if (p_ > 0) paste0("AR(", p_, "): el modelo usa los ", p_, " retornos anteriores para predecir el siguiente. ") else "",
if (d_ > 0) paste0("I(", d_, "): la serie se diferencia ", d_, " vez antes de modelar. ") else "I(0): la serie ya es estacionaria. ",
if (q_ > 0) paste0("MA(", q_, "): incluye los ultimos ", q_, " errores de prediccion como variables.") else ""
)
)
})
# --- Forecast ARIMA ---
output$eda_forecast <- renderPlotly({
df  <- df_eda()
clr <- CRYPTO_COLORS[input$eda_sym]
r   <- na.omit(df$retorno)
modelo <- tryCatch(
auto.arima(r, seasonal = FALSE, stepwise = TRUE,
approximation = TRUE, max.p = 5, max.q = 5),
error = function(e) NULL
)
if (is.null(modelo)) {
return(plot_ly() %>% layout(title = "No se pudo ajustar ARIMA. Intenta con mas datos."))
}
# forecast a 30 dias sobre retornos
fc    <- forecast(modelo, h = 30, level = 95)
precio_ult <- tail(df$close, 1)
fecha_ult  <- tail(df$fecha, 1)
# reconstruyo precios desde retornos proyectados
# precio_{t+k} = precio_{t} * prod(1 + ret_{t+i}/100)
ret_fc  <- as.numeric(fc$mean)
ret_lo  <- as.numeric(fc$lower)
ret_hi  <- as.numeric(fc$upper)
precios_fc <- cumprod(1 + ret_fc / 100) * precio_ult
precios_lo <- cumprod(1 + ret_lo / 100) * precio_ult
precios_hi <- cumprod(1 + ret_hi / 100) * precio_ult
fechas_fc  <- seq(fecha_ult + 1, by = "day", length.out = 30)
# ultimos 90 dias historicos para contexto
df_hist <- tail(df, 90)
plot_ly() %>%
# historico
add_trace(data = df_hist, x = ~fecha, y = ~close,
type = "scatter", mode = "lines",
line = list(color = clr, width = 2),
name = "Precio historico") %>%
# banda de incertidumbre
add_trace(x = c(fechas_fc, rev(fechas_fc)),
y = c(precios_hi, rev(precios_lo)),
type = "scatter", mode = "none",
fill = "toself",
fillcolor = "rgba(180,180,180,0.25)",
line = list(color = "transparent"),
showlegend = TRUE,
name = "IC 95%") %>%
# linea forecast
add_trace(x = fechas_fc, y = precios_fc,
type = "scatter", mode = "lines",
line = list(color = "#F7931A", width = 2, dash = "dash"),
name = "Forecast 30d") %>%
# punto de corte
add_vline(x = as.numeric(fecha_ult) * 86400000,
line = list(color = "#999", dash = "dot", width = 1)) %>%
layout(
xaxis = list(title = ""),
yaxis = list(title = "Precio (USD)"),
plot_bgcolor  = "#fafafa",
paper_bgcolor = "#fff",
legend        = list(orientation = "h", y = -0.15),
hovermode     = "x unified"
)
})
# ═══════════════════════════════════════════════════════════════
# TAB 6: COMPARADOR
# ═══════════════════════════════════════════════════════════════
df_comp <- reactive({
req(input$sel_syms_comp, input$sel_dias_comp)
cutoff <- Sys.Date() - input$sel_dias_comp
hist_data %>%
filter(fecha >= cutoff, simbolo %in% input$sel_syms_comp) %>%
arrange(fecha) %>%
group_by(simbolo) %>%
mutate(
ini           = first(close),
rend_base100  = close / ini * 100,
rend_pct      = (close - ini) / ini * 100
) %>% ungroup()
})
output$plot_comp <- renderPlotly({
df   <- df_comp()
yvar <- if (input$tipo_norm == "base100") "rend_base100" else "rend_pct"
ylab <- if (input$tipo_norm == "base100") "Indice (base 100)" else "Retorno acumulado (%)"
ref  <- if (input$tipo_norm == "base100") 100 else 0
p <- plot_ly()
for (sym in unique(df$simbolo)) {
d <- df %>% filter(simbolo == sym)
p <- add_trace(p, data=d, x=~fecha, y=~.data[[yvar]],
type="scatter", mode="lines",
line=list(color=CRYPTO_COLORS[sym], width=2.2),
name=sym,
hovertemplate=paste0(sym,": %{y:.1f}<extra></extra>"))
}
p %>%
add_hline(y=ref, line=list(color="#ccc", dash="dash", width=1)) %>%
layout(xaxis=list(title=""),
yaxis=list(title=ylab),
plot_bgcolor="#fafafa", paper_bgcolor="#fff",
legend=list(orientation="h", y=-0.15),
hovermode="x unified")
})
output$tabla_comp <- DT::renderDataTable({
cutoff <- Sys.Date() - input$sel_dias_comp
hist_data %>%
filter(fecha >= cutoff, simbolo %in% input$sel_syms_comp) %>%
group_by(simbolo) %>%
summarise(
`Precio Inicial`   = round(first(close), 3),
`Precio Final`     = round(last(close),  3),
`Rendimiento (%)`  = round((last(close)-first(close))/first(close)*100, 2),
`Vol. Anual (%)`   = round(sd(retorno, na.rm=TRUE)*sqrt(252), 2),
`Sharpe Anual`     = round(mean(retorno,na.rm=TRUE)/sd(retorno,na.rm=TRUE)*sqrt(252), 3),
`VaR 95% (%)`      = round(quantile(retorno, 0.05, na.rm=TRUE), 3),
`Max Precio`       = round(max(high, na.rm=TRUE), 3),
`Min Precio`       = round(min(low,  na.rm=TRUE), 3),
.groups = "drop"
) %>%
rename(Simbolo = simbolo) %>%
arrange(desc(`Rendimiento (%)`))
}, rownames=FALSE, options=list(dom="t", scrollX=TRUE, pageLength=10))
# ═══════════════════════════════════════════════════════════════
# PESTAÑA EDA HACIA EL MODELO
# ═══════════════════════════════════════════════════════════════
# datos reactivos de la moneda y periodo seleccionados
df_eda <- reactive({
req(input$eda_sym, input$eda_dias)
get_df(input$eda_sym, input$eda_dias)
})
# serie de tiempo (objeto ts diario para forecast)
ts_eda <- reactive({
df <- df_eda()
ts(df$close, frequency = 7)   # frecuencia 7 = semanal dentro de lo diario
})
# --- 1. Serie de tiempo simple ----------------------------------
output$eda_serie <- renderPlotly({
df  <- df_eda()
clr <- CRYPTO_COLORS[input$eda_sym]
plot_ly(df, x = ~fecha, y = ~close,
type = "scatter", mode = "lines",
line = list(color = clr, width = 2),
hovertemplate = "%{x|%d %b %Y}: $%{y:,.2f}<extra></extra>") %>%
layout(
xaxis = list(title = ""),
yaxis = list(title = "Precio de cierre (USD)"),
plot_bgcolor = "#fafafa", paper_bgcolor = "#fff",
hovermode = "x unified"
)
})
# --- 2. Box & Whiskers por mes ----------------------------------
output$eda_boxplot <- renderPlotly({
df <- df_eda() %>%
mutate(
mes_lbl = format(fecha, "%b %Y"),
mes_ord = as.numeric(format(fecha, "%Y%m"))
) %>%
arrange(mes_ord)
# orden cronologico de los meses
niveles <- df %>% distinct(mes_lbl, mes_ord) %>% arrange(mes_ord) %>% pull(mes_lbl)
df <- df %>% mutate(mes_lbl = factor(mes_lbl, levels = niveles))
# color por mes (gradiente del color de la moneda segun posicion)
n_meses <- length(niveles)
clr     <- CRYPTO_COLORS[input$eda_sym]
plot_ly(df, x = ~mes_lbl, y = ~close, type = "box",
color = ~mes_lbl,
colors = colorRampPalette(c(clr, "#ffffff"))(n_meses),
showlegend = FALSE,
hovertemplate = paste0(
"<b>%{x}</b><br>",
"Mediana: $%{median:,.0f}<br>",
"Q1: $%{q1:,.0f}<br>",
"Q3: $%{q3:,.0f}<extra></extra>"
)
) %>%
layout(
xaxis = list(title = "", tickangle = -40),
yaxis = list(title = "Precio de cierre (USD)"),
plot_bgcolor = "#fafafa", paper_bgcolor = "#fff",
boxmode = "group"
)
})
# --- 3. Descomposicion STL --------------------------------------
output$eda_decomp <- renderPlotly({
serie <- ts_eda()
# stl requiere al menos 2 periodos completos
if (length(serie) < 16) {
return(plot_ly() %>%
layout(title = "Se necesitan al menos 90 dias para descomponer la serie."))
}
dec <- tryCatch(
stl(serie, s.window = "periodic", robust = TRUE),
error = function(e) NULL
)
if (is.null(dec)) {
return(plot_ly() %>% layout(title = "No fue posible descomponer la serie con STL."))
}
fechas    <- df_eda()$fecha
tend      <- as.numeric(dec$time.series[, "trend"])
estac     <- as.numeric(dec$time.series[, "seasonal"])
residuo   <- as.numeric(dec$time.series[, "remainder"])
original  <- as.numeric(serie)
clr <- CRYPTO_COLORS[input$eda_sym]
subplot(
plot_ly(x = fechas, y = original, type = "scatter", mode = "lines",
line = list(color = clr, width = 1.5), name = "Original"),
plot_ly(x = fechas, y = tend, type = "scatter", mode = "lines",
line = list(color = "#e74c3c", width = 2), name = "Tendencia"),
plot_ly(x = fechas, y = estac, type = "scatter", mode = "lines",
line = list(color = "#2ecc71", width = 1.2), name = "Estacionalidad"),
plot_ly(x = fechas, y = residuo, type = "bar",
marker = list(color = "#3498db", opacity = 0.6), name = "Residuo"),
nrows = 4, shareX = TRUE, titleY = TRUE,
heights = c(0.3, 0.25, 0.2, 0.25)
) %>%
layout(
plot_bgcolor = "#fafafa", paper_bgcolor = "#fff",
showlegend = FALSE,
hovermode = "x unified",
xaxis4 = list(title = "")
)
})
# --- 4. ACF -----------------------------------------------------
output$eda_acf <- renderPlotly({
r   <- df_eda()$close
n   <- length(r)
lag_max <- min(40, n - 1)
ac  <- acf(r, lag.max = lag_max, plot = FALSE)
lags    <- as.numeric(ac$lag)
vals    <- as.numeric(ac$acf)
ci      <- qnorm(0.975) / sqrt(n)   # banda de confianza 95%
colores <- ifelse(abs(vals) > ci, "#F7931A", "#aaaaaa")
plot_ly() %>%
add_segments(x = lags, xend = lags, y = 0, yend = vals,
line = list(color = colores, width = 3)) %>%
add_markers(x = lags, y = vals,
marker = list(color = colores, size = 6)) %>%
add_hline(y =  ci, line = list(color = "#3498db", dash = "dash", width = 1)) %>%
add_hline(y = -ci, line = list(color = "#3498db", dash = "dash", width = 1)) %>%
add_hline(y = 0,   line = list(color = "#333",    width  = 0.5)) %>%
layout(
xaxis = list(title = "Rezago (dias)"),
yaxis = list(title = "Autocorrelacion", range = c(-1, 1)),
plot_bgcolor = "#fafafa", paper_bgcolor = "#fff",
showlegend = FALSE,
annotations = list(list(
x = lag_max * 0.7, y = ci + 0.05,
text = "Banda 95%", showarrow = FALSE,
font = list(size = 10, color = "#3498db")
))
)
})
# --- 4. PACF ----------------------------------------------------
output$eda_pacf <- renderPlotly({
r   <- df_eda()$close
n   <- length(r)
lag_max <- min(40, n - 1)
pac <- pacf(r, lag.max = lag_max, plot = FALSE)
lags    <- as.numeric(pac$lag)
vals    <- as.numeric(pac$acf)
ci      <- qnorm(0.975) / sqrt(n)
colores <- ifelse(abs(vals) > ci, "#9945FF", "#aaaaaa")
plot_ly() %>%
add_segments(x = lags, xend = lags, y = 0, yend = vals,
line = list(color = colores, width = 3)) %>%
add_markers(x = lags, y = vals,
marker = list(color = colores, size = 6)) %>%
add_hline(y =  ci, line = list(color = "#3498db", dash = "dash", width = 1)) %>%
add_hline(y = -ci, line = list(color = "#3498db", dash = "dash", width = 1)) %>%
add_hline(y = 0,   line = list(color = "#333",    width  = 0.5)) %>%
layout(
xaxis = list(title = "Rezago (dias)"),
yaxis = list(title = "Autocorrelacion Parcial", range = c(-1, 1)),
plot_bgcolor = "#fafafa", paper_bgcolor = "#fff",
showlegend = FALSE
)
})
# --- 5. Test ADF ------------------------------------------------
output$eda_adf_ui <- renderUI({
r <- df_eda()$close
adf_nivel <- tryCatch(adf.test(r),       error = function(e) NULL)
adf_diff1 <- tryCatch(adf.test(diff(r)), error = function(e) NULL)
render_adf <- function(res, titulo) {
if (is.null(res)) return(div("No fue posible correr el test."))
p_val    <- as.numeric(res$p.value)
es_est   <- p_val < 0.05
bg_col   <- if (es_est) "#dcfce7" else "#fee2e2"
bd_col   <- if (es_est) "#2ecc71"  else "#e74c3c"
txt_col  <- if (es_est) "#166534"  else "#991b1b"
veredicto <- if (es_est) "ESTACIONARIA" else "NO ESTACIONARIA"
div(
style = paste0(
"background:", bg_col, ";border:1px solid ", bd_col, ";",
"color:", txt_col, ";border-radius:8px;padding:12px 16px;",
"margin-bottom:10px;font-size:12.5px;"
),
tags$b(titulo), tags$br(),
paste0("Estadistico ADF: ", round(as.numeric(res$statistic), 4)), tags$br(),
paste0("p-valor: ", round(p_val, 5)), tags$br(),
tags$b(paste0("Conclusion: Serie ", veredicto)),
if (!es_est)
tags$p(style="margin:6px 0 0;font-size:11px;",
"Necesitas diferenciar la serie antes de aplicar ARIMA (usa d >= 1).")
else
tags$p(style="margin:6px 0 0;font-size:11px;",
"La serie puede usarse directamente en ARIMA sin diferenciacion (d = 0).")
)
}
tagList(
render_adf(adf_nivel, paste0("ADF sobre precio original (", input$eda_sym, ")")),
render_adf(adf_diff1, "ADF sobre primera diferencia del precio"),
div(class="narrativa",
tags$b("Por que diferenciamos:"),
" Una serie no estacionaria tiene media o varianza que cambian con el tiempo.",
" ARIMA necesita que la serie sea estacionaria para que sus predicciones tengan sentido.",
" La primera diferencia (precio de hoy menos precio de ayer) suele resolver esto."
)
)
})
# --- 6. ARIMA + Forecast ----------------------------------------
# Solo corre cuando el usuario presiona el boton
arima_resultado <- eventReactive(input$eda_run, {
withProgress(message = "Ajustando ARIMA...", value = 0.3, {
serie   <- ts_eda()
p <- input$eda_arima_p
d <- input$eda_arima_d
q <- input$eda_arima_q
h <- input$eda_horizon
modelo <- tryCatch(
Arima(serie, order = c(p, d, q)),
error = function(e) {
showNotification(
paste0("ARIMA(", p, ",", d, ",", q, ") no convergio. Prueba otros parametros."),
type = "error"
)
NULL
}
)
if (is.null(modelo)) return(NULL)
pred <- forecast(modelo, h = h)
list(modelo = modelo, pred = pred, p = p, d = d, q = q, h = h)
})
})
output$eda_forecast <- renderPlotly({
res <- arima_resultado()
if (is.null(res)) {
return(
plot_ly() %>%
layout(title = "Presiona 'Correr ARIMA' para ver la prediccion.",
plot_bgcolor="#fafafa", paper_bgcolor="#fff")
)
}
df      <- df_eda()
pred    <- res$pred
n_hist  <- nrow(df)
h       <- res$h
fechas_hist <- df$fecha
fechas_pred <- seq(max(df$fecha) + 1, by = "day", length.out = h)
vals_hist   <- df$close
vals_pred   <- as.numeric(pred$mean)
vals_lo95   <- as.numeric(pred$lower[, "95%"])
vals_hi95   <- as.numeric(pred$upper[, "95%"])
vals_lo80   <- as.numeric(pred$lower[, "80%"])
vals_hi80   <- as.numeric(pred$upper[, "80%"])
clr <- CRYPTO_COLORS[input$eda_sym]
plot_ly() %>%
# Historico
add_trace(x = fechas_hist, y = vals_hist,
type = "scatter", mode = "lines",
line = list(color = clr, width = 2),
name = "Historico") %>%
# Banda 95%
add_trace(x = c(fechas_pred, rev(fechas_pred)),
y = c(vals_hi95, rev(vals_lo95)),
type = "scatter", mode = "none",
fill = "toself",
fillcolor = "rgba(52,152,219,0.12)",
showlegend = TRUE, name = "IC 95%") %>%
# Banda 80%
add_trace(x = c(fechas_pred, rev(fechas_pred)),
y = c(vals_hi80, rev(vals_lo80)),
type = "scatter", mode = "none",
fill = "toself",
fillcolor = "rgba(52,152,219,0.22)",
showlegend = TRUE, name = "IC 80%") %>%
# Prediccion central
add_trace(x = fechas_pred, y = vals_pred,
type = "scatter", mode = "lines",
line = list(color = "#3498db", width = 2.5, dash = "dot"),
name = paste0("ARIMA(", res$p, ",", res$d, ",", res$q, ")")) %>%
# Linea vertical de corte
add_vline(x = as.numeric(max(fechas_hist)),
line = list(color = "#aaa", dash = "dash", width = 1)) %>%
layout(
xaxis = list(title = ""),
yaxis = list(title = "Precio (USD)"),
plot_bgcolor = "#fafafa", paper_bgcolor = "#fff",
legend = list(orientation = "h", y = -0.18),
hovermode = "x unified"
)
})
# --- 7. Resumen EDA para el modelo ------------------------------
output$eda_resumen <- renderUI({
df  <- df_eda()
r   <- df$close
n   <- length(r)
# Test ADF sobre nivel y primera diferencia
adf_niv  <- tryCatch(as.numeric(adf.test(r)$p.value),       error = function(e) NA)
adf_d1   <- tryCatch(as.numeric(adf.test(diff(r))$p.value), error = function(e) NA)
# Autocorrelacion en lag 1 del precio
ac1 <- tryCatch(round(acf(r, lag.max=1, plot=FALSE)$acf[2], 3), error=function(e) NA)
# Retornos
ret      <- na.omit(df$retorno)
vol_ann  <- round(sd(ret) * sqrt(252), 1)
skew_ret <- round(skewness(ret), 3)
# Nivel de diferenciacion recomendado
d_rec <- if (!is.na(adf_niv) && adf_niv >= 0.05) {
if (!is.na(adf_d1) && adf_d1 < 0.05) "d = 1 (una diferenciacion basta)"
else "d >= 2 (serie muy persistente)"
} else "d = 0 (la serie ya es estacionaria)"
tagList(
fluidRow(
column(3, div(class="schip",
span(class="schip-num", if(!is.na(ac1)) ac1 else "N/A"),
span(class="schip-lbl", "Autocorrelacion lag-1")
)),
column(3, div(class="schip",
span(class="schip-num", paste0(vol_ann, "%")),
span(class="schip-lbl", "Volatilidad anualizada")
)),
column(3, div(class="schip",
span(class="schip-num", skew_ret),
span(class="schip-lbl", "Asimetria de retornos")
)),
column(3, div(class="schip",
span(class="schip-num", d_rec),
span(class="schip-lbl", "Diferenciacion recomendada")
))
),
br(),
fluidRow(
column(4,
div(class="icard icard-orange",
tags$b("Sobre la tendencia"), tags$br(),
if (!is.na(adf_niv) && adf_niv >= 0.05)
paste0("El ADF no rechaza raiz unitaria (p=", round(adf_niv,3), ").",
" El precio tiene tendencia. Para ARIMA esto significa d >= 1.")
else
paste0("El ADF rechaza raiz unitaria (p=", round(adf_niv,3), ").",
" El precio es estacionario. d = 0 es suficiente para ARIMA.")
)
),
column(4,
div(class="icard icard-blue",
tags$b("Sobre la autocorrelacion"), tags$br(),
if (!is.na(ac1) && abs(ac1) > 0.9)
paste0("Autocorrelacion lag-1 de ", ac1, ". Alta persistencia.",
" El precio de ayer explica fuertemente el de hoy.",
" Esto es esperable en precios (no en retornos).")
else
paste0("Autocorrelacion lag-1 de ", ac1, ".",
" Consulta el ACF para decidir el orden p del modelo AR.")
)
),
column(4,
div(class="icard icard-purple",
tags$b("Que sigue: el modelo predictivo"), tags$br(),
"Con este analisis ya se puede justificar el uso de ARIMA.",
" El siguiente paso (en la siguiente entrega) es comparar ARIMA",
" contra otros modelos como Prophet o LSTM para ver cual predice mejor",
" el precio de cierre a 30 dias."
)
)
),
div(class="narrativa", style="margin-top:10px;",
tags$b("Conclusion metodologica:"),
" Los precios de criptomonedas son series no estacionarias con alta autocorrelacion.",
" Antes de modelar, es necesario diferenciar la serie (d=1 en la mayoria de casos).",
" El ACF y PACF de la serie diferenciada permiten estimar p y q.",
" ARIMA es un buen punto de partida, aunque para capturar la volatilidad",
" heteroscedastica de crypto se pueden explorar extensiones como GARCH o modelos de ML.",
" Lo que este EDA confirma: la estructura de la serie NO es ruido puro,",
" hay informacion explotable para predecir."
)
)
})
} # fin server
